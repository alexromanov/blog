---
import BaseLayout from './BaseLayout.astro';
import PostNav from '../components/PostNav.astro';
import SmartImage from '../components/SmartImage.astro';
import TableOfContents from '../components/islands/TableOfContents.astro';
import Giscus from '../components/islands/Giscus.astro';
import MathStyles from '../components/MathStyles.astro';
import { Icon } from 'astro-icon/components';
import { GISCUS, SITE, type Locale } from '../config';
import { useTranslations, stripLocale, formatDate, isoDate, localizedPath } from '../i18n/utils';
import { readingTime } from '../utils/reading-time';
import {
  type Post,
  tagPath,
  categoryPath,
  getTranslations,
  postPath,
  postSlug,
  heroImage,
  heroImageSrc,
  shouldShowHero,
} from '../utils/posts';
import { buildSeo } from '../utils/seo';
import type { MarkdownHeading } from 'astro';

interface Props {
  post: Post;
  /** Astro's `headings` array from `await render(post)`. */
  headings: MarkdownHeading[];
  /** Raw body string used for reading time. */
  body: string;
  prev?: Post;
  next?: Post;
  locale: Locale;
}

const { post, headings, body, prev, next, locale } = Astro.props;
const t = useTranslations(locale);
const minutes = readingTime(body).minutes;

// Translation siblings (used by language switcher links).
const translations = await getTranslations(post);
const translationLinks: Partial<Record<Locale, string>> = {};
for (const [lang, p] of Object.entries(translations)) {
  if (p) translationLinks[lang as Locale] = postPath(p);
}
// Locales that actually have a published version of this post.
const availableLocales = (Object.keys(translationLinks) as Locale[]).sort();

const commentsEnabled = post.data.comments !== false && GISCUS.enabled;
const pathWithoutLocale = stripLocale(Astro.url.pathname);

const heroSrc = heroImageSrc(post);
const heroAsset = heroImage(post);
const showHero = shouldShowHero(post);
const heroAlt = post.data.heroImageAlt ?? '';

const articleClass = SITE.boxedArticles
  ? 'border-base-300 bg-base-100 rounded-md border px-5 py-8 sm:px-8 sm:py-10'
  : 'px-1 py-6 sm:px-2 sm:py-8';

// Use hero image for OG if available, otherwise fallback to the generated OG image
// (unless Auto-OG is disabled globally or skipped in CI).
const ogSlug = postSlug(post);
const ogPrefix = locale === SITE.defaultLocale ? '' : `${locale}/`;
const generatedOgPath = `/og/${ogPrefix}${ogSlug}.png`;
const skipAutoOg = !SITE.autoOgImage || import.meta.env.CI_SKIP_AUTO_OG_IMAGE === 'true';
const ogImage = heroSrc ?? (skipAutoOg ? undefined : generatedOgPath);

const seo = buildSeo({
  title: post.data.title,
  description: post.data.description,
  pathWithoutLocale,
  fullPath: Astro.url.pathname,
  locale,
  ogImage,
  type: 'article',
  publishedTime: post.data.pubDate,
  modifiedTime: post.data.updatedDate,
  tags: post.data.tags,
  availableLocales,
});

const crumbs = [
  { label: t('nav.posts'), href: localizedPath('/', locale) },
  { label: post.data.title },
];
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  type="article"
  publishedTime={post.data.pubDate}
  modifiedTime={post.data.updatedDate}
  tags={post.data.tags}
  crumbs={crumbs}
  seo={seo}
  availableLocales={availableLocales}
>
  {post.data.math && <MathStyles />}
  {
    post.data.toc && headings.length > 0 && (
      <TableOfContents slot="aside-bottom" headings={headings} locale={locale} />
    )
  }

  <article class={articleClass}>
    <header class="mb-8">
      <h1
        class="text-base-content text-3xl leading-tight font-extrabold tracking-tight sm:text-[2.25rem]"
      >
        {post.data.title}
      </h1>
      <p class="text-base-content/65 mt-3 text-lg">{post.data.description}</p>

      <div class="text-base-content/70 mt-5 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm">
        <span class="inline-flex items-center gap-1">
          <Icon name="lucide:calendar-days" width={14} height={14} />
          <time datetime={isoDate(post.data.pubDate)}>{formatDate(post.data.pubDate, locale)}</time>
        </span>
        {
          post.data.updatedDate && (
            <span class="inline-flex items-center gap-1">
              <Icon name="lucide:check" width={14} height={14} />
              <time datetime={isoDate(post.data.updatedDate)}>
                {t('post.updatedOn')} {formatDate(post.data.updatedDate, locale)}
              </time>
            </span>
          )
        }
        {
          post.data.categories.length > 0 && (
            <span class="inline-flex items-center gap-1">
              <Icon name="lucide:folder" width={14} height={14} />
              {post.data.categories.map((c, i) => (
                <>
                  {i > 0 && <span class="text-base-content/40 mx-0.5">,</span>}
                  <a href={categoryPath(locale, c)} class="hover:text-primary">
                    {c}
                  </a>
                </>
              ))}
            </span>
          )
        }
        <span class="inline-flex items-center gap-1">
          <Icon name="lucide:clock" width={14} height={14} />
          {minutes}
          {t('post.readingTime')}
        </span>
      </div>
    </header>

    {
      showHero && heroAsset && (
        <figure class="post-hero mb-8">
          <div class="post-hero__frame">
            <SmartImage
              src={heroAsset}
              alt={heroAlt}
              class="post-hero__img"
              loading="eager"
              widths={[480, 768, 1024, 1280, 1600]}
              sizes="(max-width: 768px) 100vw, 1024px"
              quality={82}
            />
          </div>
          {heroAlt && (
            <figcaption class="text-base-content/70 mt-2 text-center text-xs">{heroAlt}</figcaption>
          )}
        </figure>
      )
    }

    <div class="prose-chirpy max-w-none">
      <slot />
    </div>

    {
      post.data.tags.length > 0 && (
        <footer class="border-base-300 mt-10 flex flex-wrap items-center gap-2 border-t pt-6">
          <span class="text-base-content/70 text-sm font-semibold tracking-wide uppercase">
            {t('post.tags')}
          </span>
          {post.data.tags.map((tag) => (
            <a href={tagPath(locale, tag)} class="post-tag text-xs">
              {tag}
            </a>
          ))}
        </footer>
      )
    }

    <PostNav prev={prev} next={next} locale={locale} />

    {
      commentsEnabled ? (
        <Giscus locale={locale} />
      ) : (
        post.data.comments === false && (
          <p class="text-base-content/70 mt-10 text-sm">{t('post.commentsDisabled')}</p>
        )
      )
    }
  </article>
</BaseLayout>

{/* Translation links exposed for the LanguageSwitcher to read at runtime */}
<script is:inline define:vars={{ links: translationLinks }}>
  window.__chirpyTranslations = links;
</script>
