---
import { SITE } from '~/config';

import BaseLayout from '~/layouts/BaseLayout.astro';
import { useTranslations, formatDate } from '~/i18n/utils';
import { getPosts, groupByYearMonth, postPath } from '~/utils/posts';

export function getStaticPaths() {
  return SITE.locales.map((l) => ({
    params: { locale: l === SITE.defaultLocale ? undefined : l },
    props: { locale: l },
  }));
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const posts = await getPosts(locale);
const groups = groupByYearMonth(posts, locale);
---

<BaseLayout
  title={t('archives.title')}
  pathWithoutLocale="/archives/"
  crumbs={[{ label: t('archives.title') }]}
>
  <header class="mb-6">
    <h1 class="text-3xl font-bold tracking-tight">{t('archives.title')}</h1>
  </header>
  {
    groups.length === 0 ? (
      <p class="text-base-content/70">{t('archives.empty')}</p>
    ) : (
      <div id="archives">
        {groups.map((g, gi) => {
          const yearPosts = g.months.flatMap((m) => m.posts);
          return (
            <section class:list={['year-block', { first: gi === 0 }]}>
              <time class="year">{g.year}</time>
              <ul>
                {yearPosts.map((p) => (
                  <li>
                    <span class="day">
                      {formatDate(p.data.pubDate, locale, { day: '2-digit' })}
                    </span>
                    <span class="month">
                      {formatDate(p.data.pubDate, locale, { month: 'short' })}
                    </span>
                    <a href={postPath(p)}>{p.data.title}</a>
                  </li>
                ))}
              </ul>
            </section>
          );
        })}
      </div>
    )
  }
</BaseLayout>

<style>
  /* Chirpy-style archives timeline.
     Coordinate system (px from #archives left edge):
       line:       left 77, width 4   -> center 79
       year dot:   left 73, size 12   -> center 79
       post dot:   left 75, size  8   -> center 79
     Each row reserves ~6.5rem of left padding so the date sits in fixed
     columns and the title starts a comfortable gap past the dot. */

  #archives {
    --tl-color: color-mix(in oklch, var(--color-base-content) 18%, transparent);
    --tl-node: color-mix(in oklch, var(--color-base-content) 40%, transparent);
    --tl-year-dot-bg: var(--color-base-100);
    --tl-zebra: color-mix(in oklch, var(--color-base-content) 6%, transparent);
    --tl-row-h: 2.5rem;
    letter-spacing: 0.03rem;
  }

  #archives .year-block {
    position: relative;
  }

  /* ---------- Year heading ---------- */
  #archives .year {
    display: block;
    position: relative;
    height: 3rem;
    line-height: 3rem;
    font-size: 1.5rem;
    padding-left: 6.5rem;
    color: var(--color-base-content);
  }
  /* Line segment for the year row only. The previous year's last post
     extends its own segment to its row's bottom edge, which is exactly
     this segment's top edge — they butt together with no overlap. */
  #archives .year::before {
    content: '';
    position: absolute;
    width: 4px;
    background-color: var(--tl-color);
    left: 77px;
    top: 0;
    bottom: 0;
  }
  #archives .year-block.first .year::before {
    top: 1.5rem;
  }
  #archives .year::after {
    content: '';
    position: absolute;
    border-radius: 50%;
    width: 12px;
    height: 12px;
    left: 73px;
    top: 50%;
    transform: translateY(-50%);
    border: 3px solid var(--tl-node);
    background-color: var(--tl-year-dot-bg);
    box-sizing: border-box;
    z-index: 1;
  }

  /* ---------- Post list ---------- */
  #archives ul {
    list-style: none;
    padding-left: 0;
    margin: 0;
  }

  #archives ul li {
    position: relative;
    padding-left: 6.5rem;
    height: var(--tl-row-h);
    line-height: var(--tl-row-h);
    font-size: 1.1rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  #archives ul li:nth-child(odd) {
    background-image: linear-gradient(
      to right,
      transparent 0%,
      var(--tl-zebra) 8%,
      var(--tl-zebra) 92%,
      transparent 100%
    );
  }

  #archives ul li::before {
    content: '';
    position: absolute;
    width: 4px;
    background-color: var(--tl-color);
    top: 0;
    left: 77px;
    height: calc(var(--tl-row-h) + 1px);
  }
  /* Last post of every year: end the line at the row's bottom edge so it
     doesn't overlap the next year's own line segment (which would double
     the semi-transparent fill and look darker). */
  #archives ul li:last-child::before {
    height: var(--tl-row-h);
  }
  /* Last post of the last year: trim further so the line ends at the dot. */
  #archives section:last-child ul li:last-child::before {
    height: calc(var(--tl-row-h) / 2);
  }

  /* Day + month labels: absolutely placed in the reserved left padding. */
  #archives .day,
  #archives .month {
    position: absolute;
    top: 0;
    line-height: var(--tl-row-h);
  }
  #archives .day {
    left: 0.75rem;
    font-variant-numeric: tabular-nums;
    color: var(--color-base-content);
  }
  #archives .month {
    left: 2.5rem;
    font-size: 85%;
    color: color-mix(in oklch, var(--color-base-content) 60%, transparent);
    text-transform: capitalize;
  }

  /* Title flows at the padding edge (6.5rem = 104px), giving ~21px between
     the post dot (ends at x=83) and the title text. */
  #archives a {
    color: var(--color-primary);
  }
  #archives a:hover {
    text-decoration: underline;
  }
  /* Filled circle on the timeline at the post row. */
  #archives ul li > a::before {
    content: '';
    position: absolute;
    border-radius: 50%;
    width: 8px;
    height: 8px;
    top: 50%;
    transform: translateY(-50%);
    left: 75px;
    background-color: var(--tl-node);
    z-index: 1;
  }

  @media (max-width: 575.98px) {
    #archives {
      letter-spacing: 0;
    }
  }
</style>
