---
import { SITE } from '~/config';

import BaseLayout from '~/layouts/BaseLayout.astro';
import { useTranslations } from '~/i18n/utils';
import { getTagsWithCount, tagPath } from '~/utils/posts';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  return SITE.locales.map((l) => ({
    params: { locale: l === SITE.defaultLocale ? undefined : l },
    props: { locale: l },
  }));
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const tags = await getTagsWithCount(locale);
---

<BaseLayout
  title={t('tags.title')}
  pathWithoutLocale="/tags/"
  crumbs={[{ label: t('tags.title') }]}
>
  <header class="mb-6">
    <h1 class="text-3xl font-bold tracking-tight">{t('tags.title')}</h1>
  </header>
  {
    tags.length === 0 ? (
      <p class="text-base-content/70">{t('tags.empty')}</p>
    ) : (
      <ul class="flex flex-wrap gap-2">
        {tags.map((tag) => (
          <li>
            <a href={tagPath(locale, tag.name)} class="badge badge-lg gap-1">
              <Icon name="lucide:tag" width={12} height={12} />
              {tag.name}
              <span class="text-base-content/70">{tag.count}</span>
            </a>
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>
