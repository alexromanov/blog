---
import BaseLayout from '~/layouts/BaseLayout.astro';
import PostList from '~/components/PostList.astro';
import Pagination from '~/components/Pagination.astro';
import { SITE } from '~/config';
import { localizedPath, useTranslations } from '~/i18n/utils';
import { getPosts } from '~/utils/posts';

interface Props {
  current: number;
  last: number;
  locale: any;
}

export async function getStaticPaths() {
  let paths = [];
  for (const locale of SITE.locales) {
    const allPosts = await getPosts(locale);
    const totalPages = Math.ceil(allPosts.length / SITE.postsPerPage);
    const localeParams = { locale: locale === SITE.defaultLocale ? undefined : locale };
    // Skip page 1 (handled by index.astro)
    for (let i = 2; i <= totalPages; i++) {
      paths.push({
        params: { ...localeParams, page: String(i) },
        props: { locale, current: i, last: totalPages },
      });
    }
  }
  return paths;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const { current, last } = Astro.props as Props;
const allPosts = await getPosts(locale);
const pageSize = SITE.postsPerPage;
const start = (current - 1) * pageSize;
const pagePosts = allPosts.slice(start, start + pageSize);

const hrefForPage = (n: number) => localizedPath(n === 1 ? '/' : `/page/${n}/`, locale);
---

<BaseLayout
  title={`${t('list.allPosts')} — ${t('pagination.page')} ${current}`}
  pathWithoutLocale={`/page/${current}/`}
>
  <header class="mb-6">
    <h1 class="text-3xl font-bold tracking-tight">{t('list.allPosts')}</h1>
    <p class="text-base-content/70 text-sm">
      {t('pagination.page')}
      {current}
      {t('pagination.of')}
      {last}
    </p>
  </header>
  <PostList posts={pagePosts} locale={locale} />
  <Pagination currentPage={current} lastPage={last} hrefForPage={hrefForPage} locale={locale} />
</BaseLayout>
