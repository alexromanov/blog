---
/**
 * Sticky TOC with scroll-spy.
 *
 * Renders Astro's `headings` array (H2..H4) and highlights the active
 * entry based on viewport intersection. Behavior:
 *
 *  - H2 entries are ALWAYS visible.
 *  - H3 / H4 entries are hidden by default and only revealed for the
 *    currently active H2 section (computed at render time: each child
 *    item carries `data-toc-parent="<slug-of-its-H2>"`).
 *  - The active H2 is the most recent H2 above (or containing) the
 *    currently visible heading reported by IntersectionObserver.
 */
import { useTranslations } from '../../i18n/utils';
import type { Locale } from '../../config';
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
  locale: Locale;
}

const { headings, locale } = Astro.props;
const t = useTranslations(locale);
const items = headings.filter((h) => h.depth >= 2 && h.depth <= 4);

// Pre-compute the "parent H2" slug for every item. For depth=2 it is the
// item's own slug; for depth=3/4 it is the most recent depth=2 slug
// encountered while iterating in document order.
let currentH2: string | undefined;
const decorated = items.map((h) => {
  if (h.depth === 2) currentH2 = h.slug;
  return { ...h, parent: h.depth === 2 ? h.slug : (currentH2 ?? h.slug) };
});
---

{
  items.length > 0 && (
    <nav
      aria-labelledby="toc-heading"
      class="toc sticky top-20 hidden max-h-[calc(100vh-6rem)] overflow-y-auto pr-2 text-sm xl:block"
    >
      <h2
        id="toc-heading"
        class="text-base-content/60 mb-3 text-xs font-semibold tracking-wide uppercase"
      >
        {t('post.toc')}
      </h2>
      <ol class="toc-list space-y-1">
        {decorated.map((h) => (
          <li class={`toc-level-${h.depth}`} data-toc-parent={h.parent}>
            <a href={`#${h.slug}`} data-toc-link={h.slug} data-toc-depth={h.depth}>
              {h.text}
            </a>
          </li>
        ))}
      </ol>
    </nav>
  )
}

<script>
  function initSmartToc() {
    const root = document.querySelector<HTMLElement>('.toc');
    if (!root) return;
    const links = root.querySelectorAll<HTMLAnchorElement>('[data-toc-link]');
    if (!links.length) return;

    const items = root.querySelectorAll<HTMLLIElement>('li[data-toc-parent]');

    const linkBySlug = new Map<string, HTMLAnchorElement>();
    links.forEach((a) => {
      const id = a.dataset.tocLink;
      if (id) linkBySlug.set(id, a);
    });

    // Map slug -> parent H2 slug (for child entries) for quick lookups.
    const parentBySlug = new Map<string, string>();
    items.forEach((li) => {
      const a = li.querySelector<HTMLAnchorElement>('[data-toc-link]');
      const slug = a?.dataset.tocLink;
      const parent = li.dataset.tocParent;
      if (slug && parent) parentBySlug.set(slug, parent);
    });

    const headingEls = Array.from(linkBySlug.keys())
      .map((id) => document.getElementById(id))
      .filter((el): el is HTMLElement => el !== null);

    if (!headingEls.length) return;

    function setActiveSection(activeSlug: string) {
      const activeH2 = parentBySlug.get(activeSlug) ?? activeSlug;

      links.forEach((a) =>
        a.dataset.tocLink === activeSlug
          ? a.setAttribute('data-active', 'true')
          : a.removeAttribute('data-active'),
      );

      items.forEach((li) => {
        const a = li.querySelector<HTMLAnchorElement>('[data-toc-link]');
        const depth = parseInt(a?.dataset.tocDepth ?? '2', 10);
        const parent = li.dataset.tocParent ?? '';
        if (depth === 2) {
          li.dataset.sectionActive = parent === activeH2 ? 'current' : 'true';
        } else {
          li.dataset.sectionActive = parent === activeH2 ? 'true' : 'false';
        }
      });
    }

    // Default: open the first section before any scroll happens.
    if (headingEls.length) setActiveSection(headingEls[0].id);

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
        if (!visible.length) return;
        setActiveSection(visible[0].target.id);
      },
      { rootMargin: '-80px 0px -70% 0px', threshold: 0 },
    );

    headingEls.forEach((h) => observer.observe(h));
  }

  initSmartToc();
  document.addEventListener('astro:page-load', initSmartToc);
</script>
