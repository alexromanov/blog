---
/**
 * Header search trigger + custom search modal.
 *
 * Uses Pagefind's HEADLESS API (`/_pagefind/pagefind.js`) instead of the
 * bundled `pagefind-ui` widget so we can render results with our own
 * Tailwind / daisyUI markup. None of Pagefind's CSS is loaded.
 *
 * UX:
 *   - Header button + global `/` and `Cmd/Ctrl+K` shortcuts open the modal.
 *   - Search field is at the very top of the modal with a Lucide icon.
 *   - Results are a flat list (title + URL crumb + excerpt).
 *   - Up/Down arrow keys move the highlight, Enter follows the link.
 *   - Esc / backdrop / close button close the modal AND clear state.
 */

import { useTranslations, withBase } from '../../i18n/utils';
import type { Locale } from '../../config';
import { Icon } from 'astro-icon/components';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const pagefindScript = withBase('/_pagefind/pagefind.js');

const i18n = {
  placeholder: t('search.placeholder'),
  closeLabel: t('search.closeLabel'),
  clearLabel: t('search.clearLabel'),
  typeToStart: t('search.typeToStart'),
  searching: t('search.searching'),
  noResultsFor: t('search.noResultsFor'),
  resultsCount: t('search.resultsCount'),
  resultsCountOne: t('search.resultsCountOne'),
  hintShortcut: t('search.hintShortcut'),
  hintNavigate: t('search.hintNavigate'),
  hintSelect: t('search.hintSelect'),
};
---

<button
  type="button"
  class="search-pill"
  aria-label={t('search.openLabel')}
  title={t('search.openLabel')}
  data-search-open
>
  <Icon name="lucide:search" width={16} height={16} class="search-pill__icon" />
  <span class="search-pill__label">{i18n.placeholder}</span>
  <kbd class="search-pill__kbd" aria-hidden="true">/</kbd>
</button>

<dialog
  data-search-modal
  class="modal modal-top sm:modal-middle"
  aria-label={t('search.title')}
  data-i18n={JSON.stringify(i18n)}
  data-pagefind-script={pagefindScript}
>
  <div
    class="modal-box bg-base-100 border-base-300 flex max-h-[80vh] w-full max-w-2xl flex-col overflow-hidden border p-0 shadow-2xl sm:rounded-xl"
  >
    {/* === Search row (input is the very first thing inside) === */}
    <div class="border-base-300 flex items-center gap-3 border-b px-4 py-3 sm:px-5 sm:py-3.5">
      <Icon
        name="lucide:search"
        width={18}
        height={18}
        class="text-base-content/70 shrink-0"
        aria-hidden="true"
      />
      <input
        type="search"
        data-search-input
        class="text-base-content placeholder:text-base-content/45 min-w-0 flex-1 border-0 bg-transparent text-base font-medium outline-none focus:ring-0"
        placeholder={i18n.placeholder}
        autocomplete="off"
        autocapitalize="off"
        spellcheck="false"
        aria-label={t('search.title')}
      />
      <button
        type="button"
        data-search-clear
        class="text-base-content/70 hover:bg-base-200 hover:text-base-content hidden h-7 items-center rounded-md px-2 text-xs font-medium transition"
        aria-label={i18n.clearLabel}
      >
        {i18n.clearLabel}
      </button>
      <form method="dialog" class="shrink-0">
        <button
          class="text-base-content/70 hover:bg-base-200 hover:text-base-content inline-flex h-7 w-7 items-center justify-center rounded-md transition"
          aria-label={i18n.closeLabel}
          title={i18n.closeLabel}
        >
          <Icon name="lucide:x" width={16} height={16} />
        </button>
      </form>
    </div>

    {/* === Results / state area === */}
    <div data-search-results class="min-h-0 flex-1 overflow-y-auto">
      <div class="px-5 py-12 text-center">
        <div
          class="bg-base-200 text-base-content/45 mx-auto flex h-10 w-10 items-center justify-center rounded-full"
          aria-hidden="true"
        >
          <Icon name="lucide:search" width={18} height={18} />
        </div>
        <p class="text-base-content/70 mt-3 text-sm">{i18n.typeToStart}</p>
      </div>
    </div>

    {/* === Footer with keyboard hints === */}
    <div
      class="border-base-300 bg-base-200/60 text-base-content/70 flex items-center justify-between gap-3 border-t px-4 py-2 text-[0.7rem] sm:px-5"
    >
      <div class="flex items-center gap-3">
        <span class="inline-flex items-center gap-1.5">
          <kbd class="kbd kbd-xs">↑</kbd><kbd class="kbd kbd-xs">↓</kbd>
          <span>{i18n.hintNavigate}</span>
        </span>
        <span class="hidden items-center gap-1.5 sm:inline-flex">
          <kbd class="kbd kbd-xs">↵</kbd>
          <span>{i18n.hintSelect}</span>
        </span>
      </div>
      <span class="inline-flex items-center gap-1.5">
        <kbd class="kbd kbd-xs">Esc</kbd>
        <span class="hidden sm:inline">{i18n.closeLabel}</span>
      </span>
    </div>
  </div>

  <form method="dialog" class="modal-backdrop">
    <button>close</button>
  </form>
</dialog>

<script>
  interface PagefindSearchData {
    url: string;
    excerpt?: string;
    meta?: { title?: string };
  }

  interface PagefindResult {
    data: () => Promise<PagefindSearchData>;
  }

  interface PagefindModule {
    init?: () => Promise<void>;
    // eslint-disable-next-line no-unused-vars
    search: (term: string) => Promise<{ results: PagefindResult[] } | null>;
  }

  let pagefindModule: PagefindModule | null = null;
  let loadPromise: Promise<PagefindModule> | null = null;
  /** Most recent search token — used to ignore stale async resolutions. */
  let searchToken = 0;
  let highlightIdx = -1;
  let resultLinks: HTMLElement[] = [];
  let debounceTimer: ReturnType<typeof setTimeout> | undefined;
  let PAGEFIND_SCRIPT: string | undefined;
  let I18N: Record<string, string> = {};

  function loadPagefind() {
    if (pagefindModule) return Promise.resolve(pagefindModule);
    if (loadPromise) return loadPromise;
    loadPromise = import(/* @vite-ignore */ PAGEFIND_SCRIPT as string)
      .then(async (mod) => {
        if (typeof mod.init === 'function') await mod.init();
        pagefindModule = mod;
        return mod;
      })
      .catch((err) => {
        console.error('Failed to load Pagefind', err);
        loadPromise = null;
        throw err;
      });
    return loadPromise;
  }

  function escapeHtml(s: string) {
    return String(s)
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');
  }

  /** Pagefind returns excerpts already wrapped in `<mark>` tags. We escape
   *  everything else and re-allow only the canonical `<mark>` tokens. */
  function sanitizeExcerpt(html: string) {
    const escaped = escapeHtml(html ?? '');
    return escaped.replaceAll('&lt;mark&gt;', '<mark>').replaceAll('&lt;/mark&gt;', '</mark>');
  }

  function renderState(container: HTMLElement, html: string) {
    container.innerHTML = html;
    resultLinks = Array.from(container.querySelectorAll<HTMLElement>('[data-search-result-link]'));
    highlightIdx = resultLinks.length > 0 ? 0 : -1;
    updateHighlight();
  }

  function renderIdle(container: HTMLElement) {
    renderState(
      container,
      `<div class="px-5 py-12 text-center">
        <div class="bg-base-200 text-base-content/45 mx-auto flex h-10 w-10 items-center justify-center rounded-full" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.35-4.35"/></svg>
        </div>
        <p class="text-base-content/70 mt-3 text-sm">${escapeHtml(I18N.typeToStart)}</p>
      </div>`,
    );
  }

  function renderSearching(container: HTMLElement) {
    renderState(
      container,
      `<div class="px-5 py-12 text-center">
        <p class="text-base-content/70 inline-flex items-center gap-2 text-sm">
          <span class="loading loading-spinner loading-xs" aria-hidden="true"></span>
          ${escapeHtml(I18N.searching)}
        </p>
      </div>`,
    );
  }

  function renderNoResults(container: HTMLElement, term: string) {
    renderState(
      container,
      `<div class="px-5 py-12 text-center">
        <div class="bg-base-200 text-base-content/45 mx-auto flex h-10 w-10 items-center justify-center rounded-full" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.35-4.35"/><path d="M8 11h6"/></svg>
        </div>
        <p class="text-base-content/70 mt-3 text-sm">
          ${escapeHtml(I18N.noResultsFor)}
          <span class="text-base-content font-semibold">"${escapeHtml(term)}"</span>
        </p>
      </div>`,
    );
  }

  function formatCrumb(url: string) {
    try {
      const u = new URL(url, window.location.origin);
      const parts = u.pathname.replace(/\/+$/g, '').split('/').filter(Boolean);
      if (parts.length === 0) return '/';
      return parts.join(' › ');
    } catch {
      return url;
    }
  }

  function renderResults(container: HTMLElement, results: PagefindSearchData[]) {
    const count = results.length;
    const label = count === 1 ? I18N.resultsCountOne : I18N.resultsCount;

    const items = results
      .map((r, i) => {
        const title = escapeHtml(r.meta?.title || r.url);
        const crumb = escapeHtml(formatCrumb(r.url));
        const excerpt = sanitizeExcerpt(r.excerpt || '');
        return `<li>
          <a
            data-search-result-link
            data-idx="${i}"
            href="${escapeHtml(r.url)}"
            class="search-result group block px-4 py-3 sm:px-5"
          >
            <div class="text-base-content/45 group-hover:text-primary/70 flex items-center gap-1.5 text-[0.7rem] tracking-wide uppercase">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
              <span class="truncate">${crumb}</span>
            </div>
            <h3 class="text-base-content group-hover:text-primary mt-0.5 text-[0.95rem] leading-snug font-semibold">${title}</h3>
            <p class="text-base-content/65 mt-1 line-clamp-2 text-[0.825rem] leading-snug">${excerpt}</p>
          </a>
        </li>`;
      })
      .join('');

    renderState(
      container,
      `<div>
        <div class="text-base-content/70 border-base-300 border-b px-4 py-2 text-[0.7rem] tracking-wide uppercase sm:px-5">
          ${count} ${escapeHtml(label)}
        </div>
        <ul class="divide-base-300 divide-y" role="listbox">${items}</ul>
      </div>`,
    );
  }

  function updateHighlight() {
    resultLinks.forEach((link, i) => {
      if (i === highlightIdx) {
        link.setAttribute('data-active', 'true');
        link.setAttribute('aria-selected', 'true');
        link.scrollIntoView({ block: 'nearest' });
      } else {
        link.removeAttribute('data-active');
        link.setAttribute('aria-selected', 'false');
      }
    });
  }

  function moveHighlight(delta: number) {
    if (resultLinks.length === 0) return;
    highlightIdx = (highlightIdx + delta + resultLinks.length) % resultLinks.length;
    updateHighlight();
  }

  function activateHighlight() {
    if (highlightIdx < 0 || !resultLinks[highlightIdx]) return false;
    resultLinks[highlightIdx].click();
    return true;
  }

  function init() {
    const dialog = document.querySelector<HTMLDialogElement>('[data-search-modal]');
    const input = document.querySelector<HTMLInputElement>('[data-search-input]');
    const clearBtn = document.querySelector<HTMLButtonElement>('[data-search-clear]');
    const results = document.querySelector<HTMLElement>('[data-search-results]');
    if (!dialog || !input || !results || !clearBtn) return;

    PAGEFIND_SCRIPT = dialog.dataset.pagefindScript;
    I18N = JSON.parse(dialog.dataset.i18n || '{}');

    function reset() {
      input!.value = '';
      clearBtn!.classList.add('hidden');
      clearBtn!.classList.remove('inline-flex');
      renderIdle(results!);
      searchToken++;
    }

    async function runSearch(term: string) {
      const myToken = ++searchToken;
      try {
        const pf = await loadPagefind();
        if (myToken !== searchToken) return;
        renderSearching(results!);
        const search = await pf.search(term);
        if (myToken !== searchToken) return;
        if (!search || !search.results || search.results.length === 0) {
          renderNoResults(results!, term);
          return;
        }
        const top = search.results.slice(0, 12);
        const data = await Promise.all(top.map((r: PagefindResult) => r.data()));
        if (myToken !== searchToken) return;
        renderResults(results!, data);
      } catch (err) {
        console.error(err);
        renderState(
          results!,
          `<p class="text-error px-5 py-6 text-sm">Search index not available. Run <code class="bg-base-200 rounded px-1">bun run build</code>.</p>`,
        );
      }
    }

    function onInput() {
      const term = input!.value.trim();
      if (term) {
        clearBtn!.classList.remove('hidden');
        clearBtn!.classList.add('inline-flex');
      } else {
        clearBtn!.classList.add('hidden');
        clearBtn!.classList.remove('inline-flex');
      }
      clearTimeout(debounceTimer);
      if (!term) {
        renderIdle(results!);
        return;
      }
      debounceTimer = setTimeout(() => runSearch(term), 140);
    }

    input.addEventListener('input', onInput);

    clearBtn.addEventListener('click', () => {
      reset();
      input!.focus();
    });

    // Reset whenever the dialog closes (Esc, backdrop click, close button).
    dialog.addEventListener('close', reset);

    // Keyboard nav while typing.
    input.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        moveHighlight(1);
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        moveHighlight(-1);
      } else if (e.key === 'Enter') {
        if (activateHighlight()) e.preventDefault();
      }
    });

    async function openSearch() {
      if (typeof dialog!.showModal === 'function') dialog!.showModal();
      else dialog!.setAttribute('open', '');
      // Pre-load Pagefind so the first keystroke is instant.
      loadPagefind().catch(() => {});
      requestAnimationFrame(() => input!.focus());
    }

    document.querySelectorAll('[data-search-open]').forEach((btn) => {
      btn.addEventListener('click', openSearch);
    });

    function isTypingTarget(target: EventTarget | null) {
      if (!(target instanceof HTMLElement)) return false;
      if (target.isContentEditable) return true;
      const tag = target.tagName;
      return tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT';
    }

    document.addEventListener('keydown', (e: KeyboardEvent) => {
      const isCmdK = (e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k';
      const isSlash =
        e.key === '/' && !e.metaKey && !e.ctrlKey && !e.altKey && !isTypingTarget(e.target);
      if (isCmdK || isSlash) {
        e.preventDefault();
        openSearch();
      }
    });
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>
