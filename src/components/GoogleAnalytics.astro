---
// Google Analytics 4 (gtag.js).
//
// Renders only when `PUBLIC_GA_MEASUREMENT_ID` is set AND the build is
// `import.meta.env.PROD`, so `bun run dev` never sends events.
//
// We disable gtag's automatic page_view and re-emit one on every
// `astro:page-load`, because `ClientRouter` (View Transitions) swaps the
// DOM without a full reload — the default page_view would only fire on
// the first hard navigation.
const GA_ID = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
const enabled = import.meta.env.PROD && typeof GA_ID === 'string' && GA_ID.startsWith('G-');
---

{
  enabled && (
    <>
      <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`} />
      <script is:inline define:vars={{ GA_ID }}>
        {`
          window.dataLayer = window.dataLayer || [];
          function gtag(){ dataLayer.push(arguments); }
          window.gtag = gtag;
          gtag('js', new Date());
          gtag('config', GA_ID, { send_page_view: false });

          function sendPageView() {
            gtag('event', 'page_view', {
              page_title: document.title,
              page_location: location.href,
              page_path: location.pathname + location.search,
            });
          }

          sendPageView();
          document.addEventListener('astro:page-load', sendPageView);
        `}
      </script>
    </>
  )
}
