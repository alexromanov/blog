---
/**
 * Reusable callout for MDX content. Use as:
 *   <Callout type="info" title="Heads up">…</Callout>
 */

interface Props {
  type?: 'info' | 'success' | 'warning' | 'error';
  title?: string;
}

const { type = 'info', title } = Astro.props;
---

<aside class:list={['callout', `callout-${type}`]} role="note">
  {title && <p class="mb-1 font-semibold">{title}</p>}
  <div><slot /></div>
</aside>
