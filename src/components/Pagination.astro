---
import type { Locale } from '../config';
import { useTranslations } from '../i18n/utils';
import { Icon } from 'astro-icon/components';

interface Props {
  currentPage: number;
  lastPage: number;
  /** Function that returns the URL for a given page number. */
  // eslint-disable-next-line no-unused-vars
  hrefForPage: (page: number) => string;
  locale: Locale;
}

const { currentPage, lastPage, hrefForPage, locale } = Astro.props;
const t = useTranslations(locale);

if (lastPage <= 1) return null;

const prev = currentPage > 1 ? hrefForPage(currentPage - 1) : null;
const next = currentPage < lastPage ? hrefForPage(currentPage + 1) : null;

// Compact paginator: first, current-1, current, current+1, last (with ellipses).
const numbers: Array<number | '…'> = [];
const push = (n: number | '…') => {
  if (numbers[numbers.length - 1] !== n) numbers.push(n);
};
push(1);
if (currentPage - 1 > 2) push('…');
for (let p = Math.max(2, currentPage - 1); p <= Math.min(lastPage - 1, currentPage + 1); p++)
  push(p);
if (currentPage + 1 < lastPage - 1) push('…');
if (lastPage > 1) push(lastPage);
---

<nav
  aria-label={`${t('pagination.page')} ${currentPage} ${t('pagination.of')} ${lastPage}`}
  class="my-10 flex items-center justify-between"
>
  {
    prev ? (
      <a rel="prev" href={prev} class="btn btn-sm btn-ghost gap-1">
        <Icon name="lucide:arrow-up" width={14} height={14} class="-rotate-90" />
        {t('pagination.previous')}
      </a>
    ) : (
      <button disabled class="btn btn-sm btn-ghost pointer-events-none gap-1 opacity-40">
        <Icon name="lucide:arrow-up" width={14} height={14} class="-rotate-90" />
        {t('pagination.previous')}
      </button>
    )
  }

  <ul class="join">
    {
      numbers.map((n) =>
        n === '…' ? (
          <li class="join-item btn btn-ghost btn-sm pointer-events-none">…</li>
        ) : (
          <li>
            <a
              href={hrefForPage(n)}
              aria-current={n === currentPage ? 'page' : undefined}
              class:list={['join-item btn btn-sm', n === currentPage ? 'btn-primary' : 'btn-ghost']}
            >
              {n}
            </a>
          </li>
        ),
      )
    }
  </ul>

  {
    next ? (
      <a rel="next" href={next} class="btn btn-sm btn-ghost gap-1">
        {t('pagination.next')}
        <Icon name="lucide:arrow-up" width={14} height={14} class="rotate-90" />
      </a>
    ) : (
      <button disabled class="btn btn-sm btn-ghost pointer-events-none gap-1 opacity-40">
        {t('pagination.next')}
        <Icon name="lucide:arrow-up" width={14} height={14} class="rotate-90" />
      </button>
    )
  }
</nav>
