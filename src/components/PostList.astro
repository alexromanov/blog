---
import type { Locale } from '../config';
import { useTranslations } from '../i18n/utils';
import type { Post } from '../utils/posts';
import PostCard from './PostCard.astro';

interface Props {
  posts: Post[];
  locale: Locale;
}

const { posts, locale } = Astro.props;
const t = useTranslations(locale);
---

{
  posts.length === 0 ? (
    <p class="border-base-300 text-base-content/70 rounded-md border border-dashed px-6 py-10 text-center">
      {t('list.empty')}
    </p>
  ) : (
    <div id="post-list">
      {posts.map((post, index) => (
        <PostCard post={post} locale={locale} prioritizeLcp={index === 0} />
      ))}
    </div>
  )
}
